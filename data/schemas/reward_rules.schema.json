{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reward Rules",
  "type": "object",
  "required": ["win", "draw", "participation", "enabled"],
  "properties": {
    "win": {
      "type": "object",
      "required": ["xp", "soft_currency"],
      "properties": {
        "xp": { "type": "integer" },
        "soft_currency": { "type": "integer" }
      }
    },
    "draw": {
      "type": "object",
      "required": ["xp", "soft_currency"],
      "properties": {
        "xp": { "type": "integer" },
        "soft_currency": { "type": "integer" }
      }
    },
    "participation": {
      "type": "object",
      "required": ["xp", "soft_currency"],
      "properties": {
        "xp": { "type": "integer" },
        "soft_currency": { "type": "integer" }
      }
    },
    "enabled": { "type": "boolean" }
  }
}
