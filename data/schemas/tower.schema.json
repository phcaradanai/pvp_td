{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tower",
  "type": "object",
  "required": ["id","display_name","element","role","tier","rarity","arsenal_cost","build_cost","upgrade_cost","stats","tags","counters","countered_by","unlock_id","visual_key","enabled"],
  "properties": {
    "id": {"type": "string"},
    "display_name": {"type": "string"},
    "element": {"type": "string"},
    "role": {"type": "string"},
    "tier": {"type": "integer"},
    "rarity": {"type": "string"},
    "arsenal_cost": {"type": "integer"},
    "build_cost": {"type": "integer"},
    "upgrade_cost": {"type": "integer"},
    "stats": {
      "type": "object",
      "required": ["damage","attack_speed","range","target_type","projectile_speed"],
      "properties": {
        "damage": {"type": "number"},
        "attack_speed": {"type": "number"},
        "range": {"type": "number"},
        "target_type": {"type": "string"},
        "projectile_speed": {"type": "number"}
      }
    },
    "tags": {"type": "array", "items": {"type": "string"}},
    "counters": {"type": "array", "items": {"type": "string"}},
    "countered_by": {"type": "array", "items": {"type": "string"}},
    "unlock_id": {"type": ["string", "null"]},
    "visual_key": {"type": "string"},
    "enabled": {"type": "boolean"}
  }
}
