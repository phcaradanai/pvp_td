{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Spell",
  "type": "object",
  "required": ["id","display_name","role","rarity","arsenal_cost","cast_cost","cooldown_seconds","target_rule","effect","tags","counters","countered_by","unlock_id","visual_key","enabled"],
  "properties": {
    "id": {"type": "string"},
    "display_name": {"type": "string"},
    "role": {"type": "string"},
    "rarity": {"type": "string"},
    "arsenal_cost": {"type": "integer"},
    "cast_cost": {"type": "integer"},
    "cooldown_seconds": {"type": "number"},
    "target_rule": {"type": "string"},
    "effect": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "counters": {"type": "array", "items": {"type": "string"}},
    "countered_by": {"type": "array", "items": {"type": "string"}},
    "unlock_id": {"type": ["string", "null"]},
    "visual_key": {"type": "string"},
    "enabled": {"type": "boolean"}
  }
}
