{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Arsenal Rules",
  "type": "object",
  "required": [
    "total_budget",
    "tower_slots",
    "creep_slots",
    "spell_slots",
    "relic_slots",
    "guardian_slots",
    "duplicate_rules",
    "rarity_limits",
    "required_categories",
    "enabled"
  ],
  "properties": {
    "total_budget": {
      "type": "integer"
    },
    "tower_slots": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "integer"
        },
        "max": {
          "type": "integer"
        }
      }
    },
    "creep_slots": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "integer"
        },
        "max": {
          "type": "integer"
        }
      }
    },
    "spell_slots": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "integer"
        },
        "max": {
          "type": "integer"
        }
      }
    },
    "relic_slots": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "integer"
        },
        "max": {
          "type": "integer"
        }
      }
    },
    "guardian_slots": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "integer"
        },
        "max": {
          "type": "integer"
        }
      }
    },
    "duplicate_rules": {
      "type": "string"
    },
    "rarity_limits": {
      "type": "object"
    },
    "required_categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "enabled": {
      "type": "boolean"
    }
  }
}